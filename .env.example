APP_NAME="TYPO3 to Confluence"
APP_ENV=local
APP_KEY=
APP_DEBUG=true

LOG_CHANNEL=single
LOG_LEVEL=debug

TYPO3_DB_HOST=127.0.0.1
TYPO3_DB_PORT=3306
TYPO3_DB_DATABASE=typo3
TYPO3_DB_USERNAME=root
TYPO3_DB_PASSWORD=

# Path to TYPO3 fileadmin directory (where uploaded files are stored)
TYPO3_FILEADMIN_PATH=/var/www/html/fileadmin
