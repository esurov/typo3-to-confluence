{
    "main": "artisan",
    "directories": [
        "app",
        "bootstrap",
        "config",
        "vendor"
    ],
    "exclude-composer-files": false,
    "dump-autoload": false,
    "compression": "GZ",
    "compactors": [
        "KevinGH\\Box\\Compactor\\Php",
        "KevinGH\\Box\\Compactor\\Json"
    ],
    "stub": "bin/stub.php",
    "output": "builds/typo3-to-confluence.phar",
    "chmod": "0755"
}
